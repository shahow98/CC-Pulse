<Window x:Class="ClaudeMonitor.UI.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:ClaudeMonitor.Models"
        xmlns:ui="clr-namespace:ClaudeMonitor.UI"
        Title="CC-Pulse"
        Width="220" SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <!-- Status to color converter -->
        <ui:StatusToColorConverter x:Key="StatusToColorConverter" />
        <ui:StatusToTextConverter x:Key="StatusToTextConverter" />

        <!-- Drop shadow border style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#FF1E1E2E" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5" Color="Black" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Session item template -->
        <DataTemplate DataType="{x:Type models:SessionInfo}">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Status indicator circle -->
                <Ellipse Grid.Column="0"
                         Width="14" Height="14"
                         Fill="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                         Stroke="#40FFFFFF"
                         StrokeThickness="1"
                         VerticalAlignment="Center"
                         Margin="0,0,4,0" />

                <!-- Session info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="#FFE0E0E0"
                               FontSize="12"
                               FontWeight="Medium"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToTextConverter}}"
                               Foreground="#FFA0A0A0"
                               FontSize="10" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Border Style="{StaticResource CardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="CC-Pulse"
                           Foreground="#FFCDD6F4"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <!-- Close button (minimizes to tray) -->
                <Button Grid.Column="1"
                        Content="✕"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        Foreground="#FFA0A0A0"
                        BorderThickness="0"
                        FontSize="12"
                        Padding="4,0"
                        Cursor="Hand"
                        VerticalAlignment="Center" />
            </Grid>

            <!-- Session list -->
            <ItemsControl Grid.Row="1"
                          x:Name="SessionList"
                          ItemsSource="{Binding}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <!-- Empty state -->
            <TextBlock Grid.Row="1"
                       x:Name="EmptyMessage"
                       Foreground="#FF6C7086"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Visible" />
        </Grid>
    </Border>
</Window>
