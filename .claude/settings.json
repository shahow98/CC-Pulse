{
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 .claude/hooks/session-start.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "ClaudeMonitor/Hooks/cc-pulse-hook.cmd start",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 .claude/hooks/session-start.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "ClaudeMonitor/Hooks/cc-pulse-hook.cmd start",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 .claude/hooks/session-start.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "ClaudeMonitor/Hooks/cc-pulse-hook.cmd start",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 .claude/hooks/inject-subagent-context.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "ClaudeMonitor/Hooks/cc-pulse-hook.cmd busy",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 .claude/hooks/inject-subagent-context.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "ClaudeMonitor/Hooks/cc-pulse-hook.cmd busy",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ClaudeMonitor/Hooks/cc-pulse-hook.cmd idle",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 .claude/hooks/inject-workflow-state.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "ClaudeMonitor/Hooks/cc-pulse-hook.cmd interactive",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "statusLine": {
    "type": "command",
    "command": "py -3 .claude/hooks/statusline.py"
  }
}
