<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <?define ProductName = "CC-Pulse" ?>
  <?define Manufacturer = "CC-Pulse" ?>
  <?define ProductVersion = "1.0.0" ?>
  <?define UpgradeCode = "E3A7C1D2-5B4F-4A8E-9C2D-1F3E5A7B9C0D" ?>

  <Package
    Name="$(var.ProductName)"
    Manufacturer="$(var.Manufacturer)"
    Version="$(var.ProductVersion)"
    UpgradeCode="$(var.UpgradeCode)"
    Language="1033"
    Compressed="yes"
    Codepage="65001">

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Install UI with folder selection and real EULA -->
    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!--
      Optional install features — controlled by checkboxes.
      Default to 1 (checked). When the user unchecks, the property
      is unset and the corresponding Feature Level drops to 0 (not installed).
    -->
    <Property Id="INSTALLDESKTOPSHORTCUT" Value="1" Secure="yes" />
    <Property Id="AUTOSTARTAPP" Value="1" Secure="yes" />

    <!--
      Pre-install check: verify Claude Code is installed.
      Search for ~/.claude/ directory under the user's profile.
      If not found, show a warning but allow installation to proceed
      (user may install Claude Code later).
    -->
    <Property Id="CLAUDE_DIR_FOUND" Secure="yes">
      <DirectorySearch Id="FindClaudeDir"
                       Path="[%USERPROFILE]\.claude"
                       Depth="0" />
    </Property>

    <!--
      Launch condition: warn if Claude Code is not detected.
      We don't block installation — user might install Claude Code afterwards.
      The app will also check on first launch and prompt accordingly.
    -->

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="$(var.ProductName)">
        <Directory Id="AssetsFolder" Name="Assets">
          <Directory Id="IconsFolder" Name="Icons" />
        </Directory>
        <Directory Id="HooksFolder" Name="Hooks" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="$(var.ProductName)" />
    </StandardDirectory>

    <!-- Autostart registry entry (optional, controlled by AUTOSTARTAPP checkbox) -->
    <StandardDirectory Id="TARGETDIR">
      <Component Id="AutoStartComponent" Guid="F1A2B3C4-D5E6-7890-ABCD-EF1234567890">
        <RegistryValue
          Id="AutoStartReg"
          Root="HKCU"
          Key="Software\Microsoft\Windows\CurrentVersion\Run"
          Name="$(var.ProductName)"
          Value="[INSTALLFOLDER]ClaudeMonitor.exe"
          Type="string"
          KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!--
      Store the installation folder in registry so the app can find it
      when running as a different process (e.g., for hook configuration).
    -->
    <StandardDirectory Id="TARGETDIR">
      <Component Id="InstallPathRegistry" Guid="D0E1F2A3-B4C5-6789-0ABC-DEF012345678">
        <RegistryValue
          Id="InstallPathReg"
          Root="HKCU"
          Key="Software\$(var.Manufacturer)\$(var.ProductName)"
          Name="InstallPath"
          Value="[INSTALLFOLDER]"
          Type="string"
          KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Application files -->
    <ComponentGroup Id="ApplicationFiles" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="ClaudeMonitorExe"
              Source="$(var.PublishDir)ClaudeMonitor.exe"
              KeyPath="yes" />
      </Component>

      <!-- Console-mode hook proxy for reliable stdin pipe inheritance -->
      <Component Id="HookProxyExe" Guid="A2B3C4D5-E6F7-8901-BCDE-F23456789012">
        <File Id="HookProxyExe"
              Source="$(var.HookProxyPublishDir)CC-Pulse-Hook.exe" />
      </Component>

      <Component Id="AssetsAppIco" Directory="IconsFolder" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="AppIco" Source="$(var.SourceDir)Assets\Icons\app.ico" />
      </Component>

      <Component Id="AssetsGreenIco" Directory="IconsFolder" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <File Id="GreenIco" Source="$(var.SourceDir)Assets\Icons\green.ico" />
      </Component>

      <Component Id="AssetsYellowIco" Directory="IconsFolder" Guid="D4E5F6A7-B8C9-0123-DEFA-234567890123">
        <File Id="YellowIco" Source="$(var.SourceDir)Assets\Icons\yellow.ico" />
      </Component>

      <Component Id="AssetsRedIco" Directory="IconsFolder" Guid="E5F6A7B8-C9D0-1234-EFAB-345678901234">
        <File Id="RedIco" Source="$(var.SourceDir)Assets\Icons\red.ico" />
      </Component>

      <Component Id="HookScript" Directory="HooksFolder" Guid="F6A7B8C9-D0E1-2345-FABC-456789012345">
        <File Id="HookSh" Source="$(var.HooksDir)cc-pulse-hook.sh" />
      </Component>
    </ComponentGroup>

    <!-- Start Menu shortcuts -->
    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcuts" Guid="A7B8C9D0-E1F2-3456-ABCD-567890123456">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="$(var.ProductName)"
                  Target="[INSTALLFOLDER]ClaudeMonitor.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <Shortcut Id="UninstallShortcut"
                  Name="Uninstall $(var.ProductName)"
                  Target="[SystemFolder]msiexec.exe"
                  Arguments="/x [ProductCode]" />
        <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\$(var.Manufacturer)\$(var.ProductName)"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Desktop shortcut (optional, controlled by INSTALLDESKTOPSHORTCUT checkbox) -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcutComponent" Guid="B8C9D0E1-F2A3-4567-BCDE-678901234567">
        <Shortcut Id="DesktopShortcut"
                  Name="$(var.ProductName)"
                  Target="[INSTALLFOLDER]ClaudeMonitor.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RegistryValue Root="HKCU"
                       Key="Software\$(var.Manufacturer)\$(var.ProductName)"
                       Name="DesktopShortcutInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Custom action: stop running process on uninstall -->
    <CustomAction Id="StopProcess"
                  FileRef="ClaudeMonitorExe"
                  ExeCommand="stop-process"
                  Impersonate="yes"
                  Execute="deferred"
                  Return="ignore" />

    <!-- Custom action: remove hooks on uninstall -->
    <CustomAction Id="RemoveHooks"
                  FileRef="ClaudeMonitorExe"
                  ExeCommand="remove-hooks"
                  Impersonate="yes"
                  Execute="deferred"
                  Return="ignore" />

    <!-- Install execute sequence -->
    <InstallExecuteSequence>
      <Custom Action="StopProcess" Before="RemoveHooks" Condition="REMOVE~=&quot;ALL&quot;" />
      <Custom Action="RemoveHooks" Before="RemoveFiles" Condition="REMOVE~=&quot;ALL&quot;" />
    </InstallExecuteSequence>

    <!-- Feature -->
    <Feature Id="MainFeature" Title="$(var.ProductName)" Level="1">
      <ComponentGroupRef Id="ApplicationFiles" />
      <ComponentRef Id="ApplicationShortcuts" />
      <ComponentRef Id="InstallPathRegistry" />
      <Feature Id="DesktopShortcutFeature"
               Title="Desktop Shortcut"
               Description="Create a shortcut on the desktop."
               Level="1">
        <Level Value="0" Condition="NOT INSTALLDESKTOPSHORTCUT" />
        <ComponentRef Id="DesktopShortcutComponent" />
      </Feature>
      <Feature Id="AutoStartFeature"
               Title="Auto-start on Login"
               Description="Automatically start CC-Pulse when you log in to Windows."
               Level="1">
        <Level Value="0" Condition="NOT AUTOSTARTAPP" />
        <ComponentRef Id="AutoStartComponent" />
      </Feature>
    </Feature>

    <!-- App icon for Add/Remove Programs -->
    <Icon Id="AppIcon" SourceFile="$(var.SourceDir)Assets\Icons\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <!--
      Inject an "Installation Options" dialog with checkboxes into
      the WixUI_InstallDir wizard flow:
        LicenseAgreementDlg → InstallDirDlg → InstallOptionsDlg → VerifyReadyDlg
    -->
    <UI>
      <Dialog Id="InstallOptionsDlg" Width="370" Height="270" Title="$(var.ProductName) Setup">
        <Control Id="Title" Type="Text" X="15" Y="6" Width="200" Height="15" Transparent="yes"
                 Text="{\WixUI_Font_Title}Installation Options" />
        <Control Id="Description" Type="Text" X="25" Y="23" Width="280" Height="15" Transparent="yes"
                 Text="Choose optional installation features." />
        <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44"
                 Text="WixUI_Bmp_Banner" />
        <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />

        <Control Id="DesktopShortcutCheckbox" Type="CheckBox"
                 X="20" Y="70" Width="290" Height="17"
                 Property="INSTALLDESKTOPSHORTCUT"
                 CheckBoxValue="1"
                 Text="Create a &amp;desktop shortcut" />
        <Control Id="AutoStartCheckbox" Type="CheckBox"
                 X="20" Y="95" Width="290" Height="17"
                 Property="AUTOSTARTAPP"
                 CheckBoxValue="1"
                 Text="Automatically start &amp;when logging in to Windows" />

        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17"
                 Text="&amp;Back">
          <Publish Event="NewDialog" Value="InstallDirDlg" Order="1" />
        </Control>
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17"
                 Default="yes" Text="&amp;Install">
          <Publish Event="NewDialog" Value="VerifyReadyDlg" Order="1" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17"
                 Cancel="yes" Text="Cancel">
          <Publish Event="SpawnDialog" Value="CancelDlg" />
        </Control>
      </Dialog>

      <!--
        Override the WixUI_InstallDir navigation flow to insert InstallOptionsDlg.
        In WiX v4/v5, you override a publish by providing a new one with the same
        Dialog/Control/Event and a higher Order. The original publish is suppressed.
      -->
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog"
               Value="InstallOptionsDlg" Order="5" />
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog"
               Value="InstallOptionsDlg" Order="5" />
    </UI>

  </Package>
</Wix>
